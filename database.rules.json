{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "rooms": {
          "$roomCode": {
            ".write": "auth != null && (auth.uid === $uid || root.child('rooms').child($roomCode).child('meta').child('ownerId').val() === auth.uid)"
          }
        }
      }
    },
    "rooms": {
      "$roomCode": {
        ".write": "auth != null && (data.child('meta').child('ownerId').val() === auth.uid || root.child('rooms').child($roomCode).child('players').child(auth.uid).child('role').val() === 'gm' || (!newData.exists() && data.child('players').child(auth.uid).exists()))",
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid || root.child('rooms').child($roomCode).child('players').child(auth.uid).child('role').val() === 'gm')"
        },
        "players": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$uid": {
            ".write": "auth != null && ($uid === auth.uid || root.child('rooms').child($roomCode).child('players').child(auth.uid).child('role').val() === 'gm')"
          }
        },
        "typing": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "avatars": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "chat": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "casual": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "tokens": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "mapScenes": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).child('role').val() === 'gm'"
        },
        "journals": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "handouts": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "characters": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "bgm": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        },
        "lastRoll": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()"
        }
      }
    }
  }
}
